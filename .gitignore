# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# VS-code specific files
*.code-workspace

# Docs generation
/public/resume_gen/jobs.yaml
/public/resume_gen/scripts/__pycache__/
/public/resume_gen/scripts/generate_docs.py
/public/resume_gen/templates/cover_letter_template.html
/public/resume_gen/templates/signature.png
/public/resume_gen/*(*)/
